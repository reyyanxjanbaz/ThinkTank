PORT=3001
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
# Use OPENROUTER_API_KEY for OpenRouter. If set, it takes precedence over OPENAI_API_KEY.
OPENROUTER_API_KEY=
OPENAI_BASE_URL=
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Think Tank
# Set OPENAI_MODEL explicitly only when you need a non-default model.
# Defaults:
# - OpenRouter: openai/gpt-4o-mini
# - OpenAI: gpt-4o-mini
OPENAI_MODEL=
OPENAI_TEMPERATURE=0.7
REDIS_URL=
PROMPT_PREVIEW=false
SUPABASE_STORAGE_BUCKET=artifacts
SUPABASE_EXPORT_BUCKET=exports
MAX_ARTIFACT_SIZE=5242880
# Comma-separated list of allowed web origins for CORS. Empty = allow all.
CORS_ORIGIN=http://localhost:5173
# In production this defaults to false; set true only for demo/no-database deployments.
ALLOW_MEMORY_STORE=true
