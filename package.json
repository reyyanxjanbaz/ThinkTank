{
  "name": "thinktank",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:watch": "node scripts/dev.mjs --watch-api",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:web": "npm --prefix apps/web run dev",
    "build": "npm run build:api && npm run build:web",
    "build:api": "npm --prefix apps/api run build",
    "build:web": "npm --prefix apps/web run build",
    "typecheck": "npm --prefix apps/web run typecheck && npm --prefix apps/api run build"
  }
}
